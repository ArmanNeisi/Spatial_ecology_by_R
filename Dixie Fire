# 8. Calculate dNBR (differenced NBR) - Burn Severity:---------------------

## dNBR = NBR pre fire - NBR post fire
## High dNBR values : indicate high fire severity
## It is the standard method used by USGS to assess burn severity

## IMPORTANT: Images must have matching extents to perform calculations
## Re-sample all NBR images to match the extent of the first image (july 2020)

# Re-sample all NBR to match july 2020 extent:
nbr_sept2021_res <- resample(nbr_sept2021, nbr_july2020, method="bilinear")
nbr_aug2022_res <- resample(nbr_aug2022, nbr_july2020, method="bilinear")
nbr_may2025_res <- resample(nbr_may2025, nbr_july2020, method="bilinear")


# Calculate immediate fire impact (July 2020 - september 2021):
