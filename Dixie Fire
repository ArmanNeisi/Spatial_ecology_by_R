# 5. Calculate NDVI (Normalized Difference Vegetation Index):-----------------

## NDVI formula: (NIR - Red) / (NIR + Red)
## For Landsat 8/9: NIR = Band 5, Red = Band 4
## NDVI ranges: -1 to 1
## High values (>0.4) = healthy vegetation
## Medium values (0.2 - 0.4) = sparse vegetation
## Low values (<0.2) = burned area, bare soil, rocks


# Calculate NDVI for July 2020:
ndvi_july2020 <- (dixiefire_july2020[[5]] - dixiefire_july2020[[4]]) / 
  (dixiefire_july2020[[5]] + dixiefire_july2020[[4]])

# Calculate NDVI for September 2021:
ndvi_sept2021 <- (dixiefire_spt2021[[5]] - dixiefire_spt2021[[4]]) / 
  (dixiefire_spt2021[[5]] + dixiefire_spt2021[[4]])

# Calculate NDVI for August 2022:
