# 16. PCA Analysis and Variability:------------------------------

## Principal Component Analysis reduces multi-spectral data to main components
## PC1 typically explains most of the variance in the system
## Useful to understand overall landscape heterogeneity


# Re-sample images to lower resolution for faster processing:

## factor = 10 means we aggregate 10x10 pixels into 1 pixel

dixiefire_july2020_res <- aggregate(dixiefire_july2020, fact=10)
dixiefire_spt2021_res <- aggregate(dixiefire_spt2021, fact=10)
dixiefire_may2025_res <- aggregate(dixiefire_may2025, fact=10)


# Perform PCA on key dates:

# Pre-fire (July 2020)
pca_july2020 <- rasterPCA(dixiefire_july2020_res)
summary(pca_july2020$model)  # Shows how much variance each PCA explains

# Post-fire (September 2021)
pca_spt2021 <- rasterPCA(dixiefire_spt2021_res)
summary(pca_spt2021$model)

# Long-term recovery (May 2025)
pca_may2025 <- rasterPCA(dixiefire_may2025_res)
summary(pca_may2025$model)

# Extract PC1 (first principal component) for each date:
pc1_july2020 <- pca_july2020$map$PC1
pc1_spt2021 <- pca_spt2021$map$PC1
pc1_may2025 <- pca_may2025$map$PC1

# Plot PC1 for each date using viridis plasma palette:
par(mfrow=c(1,3))
